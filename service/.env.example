# opensquad-instagram-api (serviço Railway) — variáveis de ambiente

# --- Obrigatórias ---
# Tokens aceitos no header Authorization: Bearer <token> (separados por vírgula).
# Deve conter o mesmo valor de OPENSQUAD_API_TOKEN configurado na supercorps-app.
API_TOKENS=troque-por-um-token-forte

# Porta HTTP (o Railway injeta PORT automaticamente).
PORT=8080

# Motor de geração:
#   "pipeline" (produção) — OpenRouter gera a copy + Playwright renderiza os slides;
#   "stub" — slides mock (PNG sintético), sem deps externas, para validar o encaixe.
ENGINE=pipeline

# --- Necessárias para ENGINE=pipeline ---
# Chave do OpenRouter para gerar a copy dos slides.
OPENROUTER_API_KEY=

# Modelo de copy (opcional; default abaixo).
OPENROUTER_MODEL_COPY=anthropic/claude-sonnet-5

# Busca de logos reais de marca (opcional; reservado para evolução futura).
SERPAPI_API_KEY=

# Modelo de web search para dados de marca (opcional).
OPENROUTER_MODEL_WEBSEARCH=perplexity/sonar:online
